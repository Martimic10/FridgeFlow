# FridgeFlow Environment Variables
# Copy this file to .env.local and fill in your values

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Stripe — https://dashboard.stripe.com/apikeys
# Use sk_test_... while testing, swap to sk_live_... for production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...

# Stripe webhook secret — from dashboard.stripe.com/webhooks
# Webhook endpoint: https://yourdomain.com/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Your deployed URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
